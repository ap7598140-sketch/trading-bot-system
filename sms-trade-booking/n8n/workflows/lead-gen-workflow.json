{
  "name": "Trade Bot — Lead Generator (Daily)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 12
            }
          ]
        }
      },
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300],
      "id": "1"
    },
    {
      "parameters": {
        "command": "cd /path/to/sms-trade-booking && node src/bots/leadGenBot.js"
      },
      "name": "Run Lead Gen Bot",
      "type": "n8n-nodes-base.executeCommand",
      "position": [460, 300],
      "id": "2"
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.stderr }}",
              "operation": "isNotEmpty"
            }
          ]
        }
      },
      "name": "Check for Errors",
      "type": "n8n-nodes-base.if",
      "position": [680, 300],
      "id": "3"
    },
    {
      "parameters": {
        "from": "={{ $env.TWILIO_PHONE_NUMBER }}",
        "to": "={{ $env.OWNER_PHONE }}",
        "message": "⚠️ Lead Gen Bot Error:\n{{ $json.stderr.substring(0, 200) }}"
      },
      "name": "Alert Owner on Error",
      "type": "n8n-nodes-base.twilio",
      "position": [900, 200],
      "id": "4",
      "credentials": {
        "twilioApi": {
          "id": "twilio-credentials",
          "name": "Twilio API"
        }
      }
    },
    {
      "parameters": {
        "from": "={{ $env.TWILIO_PHONE_NUMBER }}",
        "to": "={{ $env.OWNER_PHONE }}",
        "message": "✅ Lead Gen complete. Check your dashboard for new leads."
      },
      "name": "Notify Success",
      "type": "n8n-nodes-base.twilio",
      "position": [900, 400],
      "id": "5",
      "credentials": {
        "twilioApi": {
          "id": "twilio-credentials",
          "name": "Twilio API"
        }
      }
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [[ { "node": "Run Lead Gen Bot", "type": "main", "index": 0 } ]]
    },
    "Run Lead Gen Bot": {
      "main": [[ { "node": "Check for Errors", "type": "main", "index": 0 } ]]
    },
    "Check for Errors": {
      "main": [
        [ { "node": "Alert Owner on Error", "type": "main", "index": 0 } ],
        [ { "node": "Notify Success", "type": "main", "index": 0 } ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
